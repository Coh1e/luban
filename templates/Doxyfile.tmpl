# Generated by `luban doc init` — edit freely or delete and re-init.
# Tuned for a typical luban-managed C++ project: src/ sources, README.md
# as the main page, HTML output under build/doc/html.

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "{{project_name}}"
PROJECT_BRIEF          = "{{project_brief}}"
PROJECT_NUMBER         = {{project_version}}

OUTPUT_DIRECTORY       = build/doc
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
TAB_SIZE               = 4
TOC_INCLUDE_HEADINGS   = 5

# ---- Input ----
INPUT                  = src include
FILE_PATTERNS          = *.cpp *.cxx *.cc *.c *.hpp *.hxx *.hh *.h
RECURSIVE              = YES
EXCLUDE                =
EXCLUDE_PATTERNS       = */build/* */vcpkg_installed/* */third_party/*
USE_MDFILE_AS_MAINPAGE = README.md

# ---- Source browser ----
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# ---- HTML output ----
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
ENUM_VALUES_PER_LINE   = 4

# ---- Skip everything else ----
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

# ---- Diagrams ----
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO

# ---- Misc ----
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
